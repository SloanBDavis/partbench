{
  "name": "partbench",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "pnpm --filter @web-cad/web dev",
    "build": "pnpm -r build",
    "build:geometry-worker": "pnpm --filter @web-cad/web build:geometry-worker",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "smoke:v7-browser-workflow": "pnpm build && node scripts/smoke-v7-browser-workflow.mjs",
    "smoke:v7-browser-workflow:derived": "VITE_ENABLE_DERIVED_GEOMETRY=true pnpm build && PARTBENCH_V7_BROWSER_WORKFLOW_REQUIRE_GLB=true node scripts/smoke-v7-browser-workflow.mjs",
    "smoke:v8-wcad-workflow": "VITE_ENABLE_DERIVED_GEOMETRY=true pnpm build && node scripts/smoke-v7-browser-workflow.mjs",
    "smoke:v9-viewport-workflow": "VITE_ENABLE_DERIVED_GEOMETRY=true pnpm build && node scripts/smoke-v7-browser-workflow.mjs",
    "smoke:v10-browser-workflow": "VITE_ENABLE_DERIVED_GEOMETRY=true pnpm build && node scripts/smoke-v7-browser-workflow.mjs --require-v10-workflow --require-derived-mesh-cache",
    "smoke:v12-browser-workflow": "VITE_ENABLE_DERIVED_GEOMETRY=true pnpm build && node scripts/smoke-v7-browser-workflow.mjs --require-v12-workflow",
    "smoke:v13-browser-workflow": "VITE_ENABLE_DERIVED_GEOMETRY=true pnpm build && node scripts/smoke-v7-browser-workflow.mjs --require-v13-workflow",
    "smoke:v14-browser-workflow": "VITE_ENABLE_DERIVED_GEOMETRY=true pnpm build && node scripts/smoke-v7-browser-workflow.mjs --require-v14-workflow",
    "smoke:v15-step-import-workflow": "node scripts/smoke-v15-step-import-workflow.mjs",
    "smoke:v15-feature-families-workflow": "node scripts/smoke-v15-feature-families-workflow.mjs",
    "smoke:v15-expressions-workflow": "node scripts/smoke-v15-expressions-workflow.mjs",
    "smoke:v15-release-samples": "node scripts/smoke-v15-release-samples.mjs",
    "smoke:v16-sweep-loft-workflow": "node scripts/smoke-v16-release-samples.mjs --workflow=sweep-loft",
    "smoke:v16-pattern-depth-workflow": "node scripts/smoke-v16-release-samples.mjs --workflow=pattern-depth",
    "smoke:v16-expressions-v2-workflow": "node scripts/smoke-v16-release-samples.mjs --workflow=expressions-v2",
    "smoke:v16-mass-properties-workflow": "node scripts/smoke-v16-release-samples.mjs --workflow=mass-properties",
    "smoke:v16-release-samples": "node scripts/smoke-v16-release-samples.mjs",
    "smoke:v14-release-samples": "node scripts/smoke-v14-release-samples.mjs",
    "smoke:v13-release-samples": "node scripts/smoke-v13-release-samples.mjs",
    "smoke:v12-release-samples": "node scripts/smoke-v12-release-samples.mjs",
    "smoke:v11-release-samples": "node scripts/smoke-v11-release-samples.mjs",
    "smoke:v10-release-samples": "node scripts/smoke-v10-release-samples.mjs",
    "smoke:v8-release-samples": "node scripts/smoke-v8-release-samples.mjs",
    "smoke:v7-release-samples": "node scripts/smoke-v8-release-samples.mjs",
    "smoke:occt-browser": "pnpm build:geometry-worker && node scripts/smoke-occt-browser.mjs",
    "test": "pnpm -r --workspace-concurrency=1 test && pnpm test:scripts",
    "test:scripts": "vitest run scripts/*.test.mjs scripts/**/*.test.mjs",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.14"
  }
}
